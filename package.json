{
  "name": "@jaepil/uqa",
  "version": "0.1.3",
  "type": "module",
  "description": "Unified Query Algebra — multi-paradigm database engine for the browser",
  "license": "AGPL-3.0-only",
  "author": "Cognica, Inc.",
  "homepage": "https://github.com/cognica-io/uqa-js",
  "repository": {
    "type": "git",
    "url": "https://github.com/cognica-io/uqa-js.git"
  },
  "keywords": [
    "database",
    "query-algebra",
    "full-text-search",
    "vector-search",
    "graph-query",
    "bm25",
    "bayesian",
    "posting-list",
    "sql",
    "cypher",
    "browser"
  ],
  "main": "dist/uqa.umd.js",
  "module": "dist/uqa.es.js",
  "types": "dist/types/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/uqa.es.js",
      "require": "./dist/uqa.umd.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc --noEmit && vite build && tsc -p tsconfig.build.json --emitDeclarationOnly --declaration --declarationDir dist/types --outDir dist/types",
    "check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "bayesian-bm25": "^0.8.0",
    "libpg-query": "^17.7.0",
    "apache-arrow": "^18.0.0",
    "@duckdb/duckdb-wasm": "^1.29.0",
    "sql.js": "^1.11.0",
    "xterm": "^5.3.0",
    "highlight.js": "^11.10.0",
    "comlink": "^4.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "vite": "^6.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.4.0"
  }
}
